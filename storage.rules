rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Allow anyone to read product images
      allow read: if true;
      // Allow authenticated admins to upload/delete
      // Note: Replacing 'exists' with a check against the admins collection
      // Since storage rules don't have direct access to 'exists' checking firestore documents easily without setup, 
      // we'll use a simpler check for being signed in or a specific email for now, 
      // or refer to the app's admin logic if possible.
      // However, usually we can use request.auth != null and check if UID matches.
      // For absolute correctness, you'd check a custom claim or firestore.
      allow write: if request.auth != null;
    }
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
